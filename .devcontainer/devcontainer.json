{
  "name": "Ninja - Claude Code Sandbox",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "NODE_VERSION": "22"
    }
  },
  "runArgs": [
    "--env-file", ".devcontainer/.env"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },
  "remoteUser": "node",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
  "workspaceFolder": "/workspace",
  "mounts": [
    "source=ninja-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=ninja-claude-config-${devcontainerId},target=/home/node/.claude,type=volume"
  ],
  "appPort": [3000, 3001, 3002, 3003, 3004],
  "containerEnv": {
    "DEVCONTAINER": "true"
  },
  "postCreateCommand": "cd /workspace/workspace/ninja-redev && npm install",
  "postAttachCommand": "echo '\\n🥷 Ninja Dev Container ready. Run: cc\\n'"
}
